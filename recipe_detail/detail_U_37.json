{"uptown-cowboy-caviar":{"id":"uptown-cowboy-caviar","name":"Uptown Cowboy Caviar","yield":"10 servings","ingredients":[{"qty":"1","unit":"can","item":"Black beans","prep":"rinsed and drained"},{"qty":"1","unit":"can","item":"Black-eyed peas","prep":"rinsed and drained"},{"qty":"1","unit":"can","item":"Pinto beans","prep":"rinsed and drained"},{"qty":"1","unit":"can","item":"Yellow shoepeg corn","prep":"drained"},{"qty":"240","unit":"ml","item":"Diced celery","prep":null},{"qty":"1","unit":"small","item":"Bunch cilantro leaves","prep":"chopped"},{"qty":"0.5","unit":null,"item":"Red bell pepper","prep":"diced"},{"qty":"0.5","unit":null,"item":"Yellow bell pepper","prep":"diced"},{"qty":"120","unit":"ml","item":"Chopped green onion","prep":null},{"qty":"1","unit":"jar","item":"Chopped pimento peppers","prep":null},{"qty":"30","unit":"ml","item":"Minced jalapeno pepper","prep":null},{"qty":"15","unit":"ml","item":"Minced garlic","prep":null},{"qty":"120","unit":"ml","item":"Rice vinegar","prep":null},{"qty":"120","unit":"ml","item":"Extra virgin olive oil","prep":null},{"qty":"80","unit":"ml","item":"White sugar","prep":null},{"qty":"5","unit":"ml","item":"Salt","prep":null},{"qty":"2.5","unit":"ml","item":"Ground black pepper","prep":null}],"instructions":["Combine black beans, black-eyed peas, pinto beans, shoepeg corn, celery, cilantro, bell peppers, green onion, pimentos, jalapeño, and garlic in a large bowl. Set aside.","Bring rice wine vinegar, olive oil, sugar, salt, and black pepper to a boil in a saucepan over medium-high heat until sugar dissolved, about 5 minutes. Cool to room temperature, then pour over bean mixture. Cover and refrigerate for 2 hours or overnight. Drain before serving."],"dietary_tags":["vegetarian","vegan","gluten-free"],"category":"Dinner","cuisine":"U.S.","source":"allrecipes","source_url":"https://www.allrecipes.com/recipe/218884/uptown-cowboy-caviar/","protein":["beef"]}}
