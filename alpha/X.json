u03b1\u03ba\u03b1\u03c4\u03b5\u03cd\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c3\u03c4\u03b7\u03bd \u03b1\u03c1\u03c7\u03ae \u03bc\u03b5 \u03ad\u03bd\u03b1 \u03ba\u03bf\u03c5\u03c4\u03ac\u03bb\u03b9, \u03c0\u03c1\u03bf\u03c3\u03b8\u03ad\u03c4\u03bf\u03c5\u03bc\u03b5 \u03c4\u03bf \u03b1\u03bb\u03b5\u03cd\u03c1\u03b9 \u03bc\u03ad\u03c7\u03c1\u03b9 \u03bd\u03b1 \u03c3\u03c7\u03b7\u03bc\u03b1\u03c4\u03b9\u03c3\u03c4\u03b5\u03af \u03b6\u03cd\u03bc\u03b7.","\u039c\u03b5\u03c4\u03ac \u03bc\u03b5 \u03c4\u03b1 \u03c7\u03ad\u03c1\u03b9\u03b1 \u03b6\u03c5\u03bc\u03ce\u03bd\u03bf\u03c5\u03bc\u03b5 \u03c0\u03c1\u03bf\u03c3\u03b8\u03ad\u03c4\u03bf\u03bd\u03c4\u03b1\u03c2 \u03b1\u03bb\u03b5\u03cd\u03c1\u03b9 \u03bc\u03ad\u03c7\u03c1\u03b9 \u03bd\u03b1 \u03ba\u03b1\u03b8\u03b1\u03c1\u03af\u03c3\u03b5\u03b9 \u03c4\u03b5\u03bb\u03b5\u03af\u03c9\u03c2 \u03c4\u03bf \u03bc\u03c0\u03bf\u03bb \u03b1\u03c0\u03cc \u03c5\u03c0\u03cc\u03bb\u03bf\u03b9\u03c0\u03b1 \u03b6\u03cd\u03bc\u03b7\u03c2.","\u0397 \u03b6\u03cd\u03bc\u03b7 \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03b5\u03af\u03bd\u03b1\u03b9 \u03c3\u03c4\u03b1\u03b8\u03b5\u03c1\u03ae \u03c7\u03c9\u03c1\u03af\u03c2 \u03bd\u03b1 \u03ba\u03bf\u03bb\u03bb\u03ac\u03b5\u03b9 \u03c3\u03c4\u03b1 \u03c7\u03ad\u03c1\u03b9\u03b1.","\u03a4\u03b7\u03bd \u03c4\u03bf\u03c0\u03bf\u03b8\u03b5\u03c4\u03bf\u03cd\u03bc\u03b5 \u03c3\u03b5 \u03ad\u03bd\u03b1 \u03bc\u03c0\u03bf\u03bb \u03ba\u03b1\u03b9 \u03c4\u03b7\u03bd \u03c3\u03ba\u03b5\u03c0\u03ac\u03b6\u03bf\u03c5\u03bc\u03b5 \u03ba\u03b1\u03b9 \u03c4\u03b7\u03bd \u03b1\u03c6\u03ae\u03bd\u03bf\u03c5\u03bc\u03b5 \u03bd\u03b1 \u03be\u03b5\u03ba\u03bf\u03c5\u03c1\u03b1\u03c3\u03c4\u03b5\u03af \u03c4\u03bf \u03bb\u03b9\u03b3\u03cc\u03c4\u03b5\u03c1\u03bf \u03b3\u03b9\u03b1 30\u00b4.","\u039a\u03cc\u03b2\u03bf\u03c5\u03bc\u03b5 \u03ba\u03bf\u03bc\u03bc\u03ac\u03c4\u03b9\u03b1 \u03b6\u03cd\u03bc\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03b9\u03b4\u03b1\u03bd\u03b9\u03ba\u03ac \u03b1\u03bd\u03bf\u03af\u03b3\u03bf\u03c5\u03bc\u03b5 \u03bb\u03b5\u03c0\u03c4\u03cc \u03c6\u03cd\u03bb\u03bb\u03bf \u03c0\u03c1\u03bf\u03c3\u03b8\u03ad\u03c4\u03bf\u03bd\u03c4\u03b1\u03c2 \u03b1\u03bb\u03b5\u03cd\u03c1\u03b9 \u03c3\u03c4\u03b7\u03bd \u03bc\u03b7\u03c7\u03b1\u03bd\u03ae \u03c4\u03c9\u03bd \u03b6\u03c5\u03bc\u03b1\u03c1\u03b9\u03ba\u03ce\u03bd.","\u039e\u03b5\u03ba\u03b9\u03bd\u03ac\u03bc\u03b5 \u03b1\u03c0\u03cc \u03c7\u03bf\u03bd\u03c4\u03c1\u03cc \u03c6\u03cd\u03bb\u03bb\u03bf \u03ba\u03b1\u03b9 \u03c3\u03c4\u03b1\u03b4\u03b9\u03b1\u03ba\u03ac \u03bc\u03b5\u03b9\u03ce\u03bd\u03bf\u03c5\u03bc\u03b5 \u03c4\u03bf \u03c0\u03ac\u03c7\u03bf\u03c2 \u03c0\u03b1\u03c3\u03c0\u03b1\u03bb\u03af\u03b6\u03bf\u03bd\u03c4\u03b1\u03c2 \u03bc\u03b5 \u03b1\u03bb\u03b5\u03cd\u03c1\u03b9.","\u038c\u03c4\u03b1\u03bd \u03b3\u03af\u03bd\u03b5\u03b9 \u03c0\u03bf\u03bb\u03cd \u03bb\u03b5\u03c0\u03c4\u03cc \u03c4\u03bf \u03c6\u03cd\u03bb\u03bb\u03bf \u03ba\u03cc\u03b2\u03bf\u03c5\u03bc\u03b5 \u03c3\u03b5 \u03bb\u03b5\u03c0\u03c4\u03ad\u03c2 \u03bb\u03c9\u03c1\u03af\u03b4\u03b5\u03c2 \u03bc\u03b5 \u03c1\u03bf\u03b4\u03ac\u03ba\u03b9 \u03c6\u03cd\u03bb\u03bb\u03bf\u03c5 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03ba\u03ac\u03bd\u03b5\u03b9 \u03b4\u03b1\u03bd\u03c4\u03b5\u03bb\u03c9\u03c4\u03ac \u03c4\u03b5\u03bb\u03b5\u03b9\u03ce\u03bc\u03b1\u03c4\u03b1.","\u0396\u03b5\u03c3\u03c4\u03b1\u03af\u03bd\u03bf\u03c5\u03bc\u03b5 \u03bc\u03c0\u03cc\u03bb\u03b9\u03ba\u03bf \u03b5\u03bb\u03b1\u03b9\u03cc\u03bb\u03b1\u03b4\u03bf \u03c3\u03b5 \u03c1\u03b7\u03c7\u03ae \u03ba\u03b1\u03c4\u03c3\u03b1\u03c1\u03cc\u03bb\u03b1 \u03c3\u03b5 \u03bc\u03ad\u03c4\u03c1\u03b9\u03b1 \u03ad\u03bd\u03c4\u03b1\u03c3\u03b7. \u0397 \u03b4\u03c5\u03bd\u03b1\u03c4\u03ae \u03c6\u03c9\u03c4\u03b9\u03ac \u03b8\u03b1 \u03c4\u03b1 \u03b4\u03ce\u03c3\u03b5\u03b9 \u03c3\u03ba\u03bf\u03cd\u03c1\u03bf \u03c7\u03c1\u03ce\u03bc\u03b1 \u03ba\u03b1\u03b9 \u03c0\u03b9\u03ba\u03c1\u03ae \u03b3\u03b5\u03cd\u03c3\u03b7.","\u0397 \u03b4\u03b9\u03b1\u03b4\u03b9\u03ba\u03b1\u03c3\u03af\u03b1 \u03c4\u03c5\u03bb\u03af\u03b3\u03bc\u03b1\u03c4\u03cc\u03c2 \u03c4\u03bf\u03c5, \u03c3\u03b5 \u03c3\u03c7\u03ae\u03bc\u03b1 \u03c4\u03c1\u03b9\u03b1\u03bd\u03c4\u03ac\u03c6\u03c5\u03bb\u03bb\u03bf, \u03b5\u03af\u03bd\u03b1\u03b9 \u03bb\u03af\u03b3\u03bf \u03c0\u03b5\u03c1\u03af\u03c0\u03bb\u03bf\u03ba\u03b7 \u03ba\u03b9 \u03b1\u03c0\u03b1\u03b9\u03c4\u03b5\u03af\u03c4\u03b1\u03b9 \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03af\u03b1. \u039c\u03b5 \u03c4\u03b7\u03bd \u03b2\u03bf\u03ae\u03b8\u03b5\u03b9\u03b1 \u03bc\u03b9\u03b1\u03c2 \u03c0\u03b9\u03c1\u03bf\u03cd\u03bd\u03b1\u03c2 \u03c4\u03c5\u03bb\u03af\u03b3\u03bf\u03c5\u03bc\u03b5 \u03c4\u03b7\u03bd \u03b1\u03c1\u03c7\u03ae \u03c4\u03b7\u03c2 \u03b6\u03cd\u03bc\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03b2\u03c5\u03b8\u03af\u03b6\u03bf\u03c5\u03bc\u03b5 \u03c3\u03c4\u03bf \u03ba\u03b1\u03c5\u03c4\u03cc \u03bb\u03ac\u03b4\u03b9 \u03c3\u03c4\u03c1\u03af\u03b2\u03bf\u03bd\u03c4\u03b1\u03c2 \u03bc\u03b5 \u03b3\u03c1\u03ae\u03b3\u03bf\u03c1\u03bf \u03ba\u03af\u03bd\u03b7\u03c3\u03b7 \u03c3\u03b5 \u03c1\u03bf\u03bb\u03cc \u03b3\u03cd\u03c1\u03c9 \u03b1\u03c0\u03cc \u03c4\u03b7\u03bd \u03c0\u03b9\u03c1\u03bf\u03cd\u03bd\u03b1.","\u0395\u03bd\u03b1\u03bb\u03bb\u03b1\u03ba\u03c4\u03b9\u03ba\u03ac \u03bc\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03b4\u03ce\u03c3\u03b5\u03c4\u03b5 \u03b1\u03c0\u03bb\u03cc \u03c3\u03c7\u03ae\u03bc\u03b1 \u03bc\u03b5 \u03c4\u03b1 \u03c7\u03ad\u03c1\u03b9\u03b1.","\u03a4\u03b7\u03b3\u03b1\u03bd\u03af\u03b6\u03bf\u03c5\u03bc\u03b5 \u03b5\u03bb\u03ac\u03c7\u03b9\u03c3\u03c4\u03b1 \u03bc\u03ad\u03c7\u03c1\u03b9 \u03bd\u03b1 \u03c6\u03bf\u03c5\u03c3\u03ba\u03b1\u03bb\u03b9\u03ac\u03c3\u03b5\u03b9 \u03b7 \u03b6\u03cd\u03bc\u03b7 \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03be\u03b1\u03bd\u03b8\u03cd\u03bd\u03b5\u03b9 \u03b5\u03bb\u03b1\u03c6\u03c1\u03ac.","\u039b\u03af\u03b3\u03b1 \u03bb\u03af\u03b3\u03b1 \u03c4\u03b1 \u03c4\u03b7\u03b3\u03b1\u03bd\u03af\u03b6\u03bf\u03c5\u03bc\u03b5 