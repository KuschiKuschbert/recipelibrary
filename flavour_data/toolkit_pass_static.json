{"fix_the_dish":[{"id":"flat","problem":"Flat / Bland","diagnosis":"Underseasoned, no salt backbone","fixes":[{"action":"Add salt","options":["kosher salt","flaky sea salt","soy sauce","fish sauce","miso"],"priority":"primary"},{"action":"Layer seasoning","options":["season at each stage, not just at the end"],"priority":"secondary"}],"rule":"Salt enhances everything. Layer it throughout cooking."},{"id":"too_rich","problem":"Too Rich / Heavy","diagnosis":"Fat or cream dominant, palate fatigue","fixes":[{"action":"Add acid","options":["lemon juice","verjuice","sumac","tamarind","vinegar"],"priority":"primary"},{"action":"Add brightness","options":["fresh herbs","citrus zest","raw shallot","pickled veg"],"priority":"secondary"}],"rule":"Every rich dish needs an acid counterpoint."},{"id":"too_sharp","problem":"Too Sharp / Acidic","diagnosis":"Acid overpowering other flavours","fixes":[{"action":"Add fat","options":["butter","olive oil","cream","coconut milk","tahini"],"priority":"primary"},{"action":"Add sweet","options":["honey","sugar","roasted garlic","caramelised onion"],"priority":"secondary"}],"rule":"Fat rounds and carries. Tames acid."},{"id":"too_bitter","problem":"Too Bitter","diagnosis":"Bitterness from char, greens, or over-extraction","fixes":[{"action":"Add salt","options":["salt directly kills bitterness"],"priority":"primary"},{"action":"Add fat + sweet","options":["butter","cream","honey","sugar"],"priority":"secondary"}],"rule":"Salt is the #1 bitterness killer."},{"id":"too_sweet","problem":"Too Sweet","diagnosis":"Sugar or natural sweetness overwhelming","fixes":[{"action":"Add acid","options":["citrus juice","vinegar","tamarind"],"priority":"primary"},{"action":"Add heat or bitter","options":["chili","black pepper","bitter greens"],"priority":"secondary"}],"rule":"Acid cuts sweet. Always."},{"id":"one_note","problem":"One-Note / Monotone","diagnosis":"All flavours from same family","fixes":[{"action":"Add contrast spice","options":["choose a spice from a different aroma family"],"priority":"primary"},{"action":"Add textural contrast","options":["crunch","cream","raw element"],"priority":"secondary"}],"rule":"Same family = harmony base. Different family = your signature."},{"id":"muddy","problem":"Muddy / Confused","diagnosis":"Too many flavours competing, no clarity","fixes":[{"action":"Add brightness","options":["fresh herb","acid","citrus zest"],"priority":"primary"},{"action":"Simplify","options":["remove one element","reduce sauce for concentration"],"priority":"secondary"}],"rule":"Bright herb + acid + zest cuts through mud."},{"id":"no_depth","problem":"No Depth / Thin","diagnosis":"Missing umami or base note layer","fixes":[{"action":"Add umami","options":["soy sauce","miso","roast garlic","Parmesan rind","tomato paste","mushroom"],"priority":"primary"},{"action":"Add roasted/caramelised element","options":["brown butter","toasted nuts","charred onion"],"priority":"secondary"}],"rule":"Umami is invisible depth. Every dish needs some."}],"balance_rules":{"salt":"Enhances everything. Layer it.","fat":"Carries flavour. Bloom spices in oil.","acid":"Brightens. Every rich dish needs it.","heat":"Transforms. Different temp = different result.","harmony":"Same aroma family = your base.","contrast":"Different aroma family = your signature."}}